# ========== 生产环境配置模板 ==========
# 复制此文件为 .env 并填入实际值

# Database (PostgreSQL)
DATABASE_URL=postgresql://himart_user:himart_password@localhost:5432/himart_db
DB_NAME=himart_db
DB_USER=himart_user
DB_PASSWORD=himart_password
DB_HOST=localhost
DB_PORT=5432

# Django
SECRET_KEY=your-very-secure-secret-key-change-this-in-production
DEBUG=False
ALLOWED_HOSTS=64.181.193.238,localhost,127.0.0.1

# JWT 认证
JWT_SECRET=your-jwt-secret-key
JWT_EXPIRATION_HOURS=24

# M-Pesa 支付集成
MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
MPESA_SHORTCODE=123456
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd1a503b30
MPESA_ENVIRONMENT=production

# Stripe 支付集成
STRIPE_PUBLIC_KEY=pk_live_your_stripe_public_key
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# 电子邮件配置
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password

# AWS S3 (可选，用于图片存储)
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=

# Redis 缓存
REDIS_URL=redis://localhost:6379/0

# CORS 配置
CORS_ALLOWED_ORIGINS=http://64.181.193.238,https://yourdomain.com
